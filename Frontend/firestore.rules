rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'fazaljuvekar.54@gmail.com';
    }

    // ── Top-level user profiles (role storage used by the app) ──
    match /users/{userId} {
      // Admin can read and write all user profiles (including listing the full collection)
      allow read, write: if isAdmin();
      // Any authenticated user can read their own profile or other profiles (for worker info, ratings)
      allow read: if request.auth != null;
      // Users can update their own profile or anyone can update rating/reviewCount
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        (request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['rating', 'reviewCount']))
      );
    }

    // ── Per-user bookings ──
    match /artifacts/{appId}/users/{userId}/bookings/{bookingId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Worker jobs (assigned by admin/system) ──
    match /artifacts/{appId}/workers/{workerId}/jobs/{jobId} {
      allow read: if request.auth != null && request.auth.uid == workerId;
      allow write: if request.auth != null && request.auth.uid == workerId;
    }

    // ── Legacy paths (kept for backward compatibility) ──
    match /artifacts/{appId}/public/data/users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /artifacts/{appId}/public/data/requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.creatorId == request.auth.uid ||
         resource.data.workerId == request.auth.uid);
      allow delete: if false;
    }

    // ── Consolidated Bookings (New Logic) ──
    match /bookings/{bookingId} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (request.auth != null && (
        resource.data.clientId == request.auth.uid || 
        resource.data.workerId == request.auth.uid ||
        resource.data.status == 'pending'
      ));
      allow update: if isAdmin() || (request.auth != null && (
        (resource.data.status == 'pending' && request.resource.data.status == 'accepted' && request.resource.data.workerId == request.auth.uid) ||
        resource.data.clientId == request.auth.uid ||
        resource.data.workerId == request.auth.uid
      ));
      allow delete: if isAdmin();

      // Chat Messages
      match /messages/{messageId} {
        allow read, create: if isAdmin() || (request.auth != null && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.clientId == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.workerId == request.auth.uid
        ));
      }
    }

    // ── Reviews ──
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if isAdmin() || (request.auth != null && request.resource.data.customerId == request.auth.uid);
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.customerId == request.auth.uid);
    }

    // ── Complaints ──
    match /complaints/{complaintId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ── Receipts ──
    match /receipts/{receiptId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
      allow update, delete: if false;
    }
  }
}
